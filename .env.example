CHAIN_ID=1

# RPC. Mainnet examples: Alchemy/Infura/publicnode. Sepolia: ethereum-sepolia-rpc.publicnode.com.
# Must be HTTPS for the worker; WS is optional.
RPC_HTTP_URL=https://ethereum-rpc.publicnode.com
RPC_WS_URL=wss://ethereum-rpc.publicnode.com

# ----- Contract addresses (auto-filled by `npm run launch`) -----
# BOUNTY_HOOK_ADDRESS  = BountyHookCore (events the worker ingests). NOT the v4 hook.
# REAL_V4_HOOK_ADDRESS = BountyV4Hook   (afterSwap reporter into core).
# BOUNTY_TOKEN_ADDRESS = ERC-20 launch token.
# POLICY_ADDRESS       = NetSellPressureBountyPolicy.
BOUNTY_HOOK_ADDRESS=
BOUNTY_TOKEN_ADDRESS=
REAL_V4_HOOK_ADDRESS=
POLICY_ADDRESS=

# Optional. Leave UNSET — the deploy script picks the right v4 plumbing
# automatically per CHAIN_ID. Setting these wrong will brick the hook.
# V4_POOL_MANAGER=
# V4_POSITION_MANAGER=
# PERMIT2_ADDRESS=
# UNIVERSAL_ROUTER=

# ----- Pool key fields (filled by `npm run launch:wire-pool`) -----
# Native ETH launch defaults to fee=3000, tickSpacing=60 (0.3% / standard).
POOL_ID=
V4_FEE=3000
V4_TICK_SPACING=60

# Optional: second pool to probe with npm run doctor (older deployments).
# LEGACY_POOL_ID=0x04015cac8383039b6b4864bbadbd0647993047502c0a0d1a5c5d03be1ab58c73
# LEGACY_V4_FEE=3000
# LEGACY_V4_TICK_SPACING=60

# Only needed for WETH pool init scripts — native ETH launch does not need these on-chain.
WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
SQRT_PRICE_X96=79228162514264337593543950336

# API
API_HOST=0.0.0.0
API_PORT=4311
API_SEED_DEMO_DATA=true

# Worker. Auto-set by `npm run launch` to the block your token deployed at.
WORKER_INGEST_SECRET=change-me-local
WORKER_START_BLOCK=
WORKER_POLL_INTERVAL_MS=12000
WORKER_CHECKPOINT_FILE=apps/worker/.checkpoint

# Forge deploy / verify (never commit real keys)
PRIVATE_KEY=
ETHERSCAN_API_KEY=

# Optional token branding (used by deploy script — defaults: "Only Up" / "UP")
TOKEN_NAME=Only Up
TOKEN_SYMBOL=UP

# Optional. Minimum sell amount in token units that opens a bounty window.
# Defaults to 10 ether (10 UP) if unset.
# MIN_DUMP_AMOUNT=10000000000000000000

# Web — mirror token/hook/fee/tick so V4SwapPanel matches your PoolKey.
# Auto-mirrored from the values above by `npm run launch` and `launch:wire-pool`.
# Push these same values to Vercel → Project → Settings → Environment Variables.
NEXT_PUBLIC_API_URL=http://localhost:4311
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_RPC_HTTP_URL=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_BOUNTY_TOKEN_ADDRESS=
NEXT_PUBLIC_REAL_V4_HOOK_ADDRESS=
NEXT_PUBLIC_V4_POOL_FEE=3000
NEXT_PUBLIC_V4_TICK_SPACING=60
NEXT_PUBLIC_BOUNTY_HOOK_ADDRESS=

# Optional bot integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ----- npm run remove (RemoveLiquidityFast) -----
# Zero-config — just type `npm run remove`. Token id is auto-detected from
# PositionManager NFT mints, gas is auto-boosted 10x, full liquidity removed.
# Override via CLI flags if you ever need to: --tokenId N, --gasMultiplier N.
REMOVE_TOKEN_ID=
REMOVE_MULTIPLIER=10
REMOVE_GAS_MULTIPLIER=10
