CHAIN_ID=11155111

# RPC (must be https for the worker; ws is optional). Used by forge [rpc_endpoints] sepolia.
RPC_HTTP_URL=https://ethereum-sepolia-rpc.publicnode.com
RPC_WS_URL=wss://ethereum-sepolia-rpc.publicnode.com

# Deployed Sepolia addresses (live).
# BOUNTY_HOOK_ADDRESS is BountyHookCore (events the worker ingests). NOT the v4 hook.
BOUNTY_HOOK_ADDRESS=0x50353c58366e5B5E693B48875EDA62390B04Eb5D
BOUNTY_TOKEN_ADDRESS=0x7026FA995927e9B9A52B5F558E4E4952A1901D70
REAL_V4_HOOK_ADDRESS=0x523AEA8bE80b51Bf69AFFcB13dB0c140ba344040
V4_POOL_MANAGER=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543

# Native ETH pool (DeployNativeEthRealV4Launch: fee=10000, tickSpacing=200). Must match your forge deploy.
POOL_ID=0x090d15173733f4ba3f2b691c0d3f5cebf85d38cb6f5c65630bff81cea6084e12
V4_FEE=10000
V4_TICK_SPACING=200

# Optional: second pool to probe with npm run doctor (older deployments).
# LEGACY_POOL_ID=0x04015cac8383039b6b4864bbadbd0647993047502c0a0d1a5c5d03be1ab58c73
# LEGACY_V4_FEE=3000
# LEGACY_V4_TICK_SPACING=60

# Only needed for WETH pool init scripts — native ETH launch does not need these on-chain.
WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14
SQRT_PRICE_X96=79228162514264337593543950336

# API
API_HOST=0.0.0.0
API_PORT=4311
API_SEED_DEMO_DATA=true

# Worker. Pick a recent start block; worker chunks the range in 5k batches so
# values older than ~50k blocks ago will be slow but not rejected.
WORKER_INGEST_SECRET=change-me-local
WORKER_START_BLOCK=10780000
WORKER_POLL_INTERVAL_MS=12000
WORKER_CHECKPOINT_FILE=apps/worker/.checkpoint

# Forge deploy / verify (never commit real keys)
PRIVATE_KEY=
ETHERSCAN_API_KEY=

# Web — mirror token/hook/fee/tick so V4SwapPanel matches your PoolKey (defaults 10000/200 native ETH).
NEXT_PUBLIC_API_URL=http://localhost:4311
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_RPC_HTTP_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_BOUNTY_TOKEN_ADDRESS=0x7026FA995927e9B9A52B5F558E4E4952A1901D70
NEXT_PUBLIC_REAL_V4_HOOK_ADDRESS=0x523AEA8bE80b51Bf69AFFcB13dB0c140ba344040
NEXT_PUBLIC_V4_POOL_FEE=10000
NEXT_PUBLIC_V4_TICK_SPACING=200
NEXT_PUBLIC_BOUNTY_HOOK_ADDRESS=0x50353c58366e5B5E693B48875EDA62390B04Eb5D

# Optional bot integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
